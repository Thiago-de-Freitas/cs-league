# gamers-league-back — variáveis do serviço API (Root Directory = /)
# Importar: railway variable import --file railway.back.env --service gamers-league-back --yes
# Ou colar no RAW Editor do serviço no dashboard Railway.
#
# Pré-requisito: Project Settings → Shared Variables → JWT_SECRET (32+ chars, ex.: openssl rand -hex 32)
# Nomes dos serviços abaixo devem coincidir com os nomes no dashboard Railway.
#
# Seed manual (npx prisma db seed): defina ADMIN_EMAIL e ADMIN_PASS no ambiente antes de rodar.

NODE_ENV=production
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}
JWT_SECRET=${{shared.JWT_SECRET}}
JWT_EXPIRES_IN=2d
CORS_ORIGIN=https://${{gamers-league-front.RAILWAY_PUBLIC_DOMAIN}}
DEMO_STORAGE_PATH=/data/demos
TEAM_LOGO_STORAGE_PATH=/data/team-logos
USER_AVATAR_STORAGE_PATH=/data/user-avatars
HIGHLIGHT_CLIPS_PATH=/data/highlights
# E-mail (verificação de conta)
# Dev local: EMAIL_PROVIDER=console (código nos logs da API)
#
# SMTP / Nodemailer:
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.seudominio.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=Gamers League <punkcodesolution@gmail.com>
#
# Resend (API HTTP):
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# EMAIL_FROM=Gamers League <punkcodesolution@gmail.com>

INTERNAL_SERVICE_KEY=${{shared.INTERNAL_SERVICE_KEY}}
