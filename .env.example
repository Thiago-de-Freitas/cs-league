# =============================================================================
# CS League — variáveis de ambiente (copie para .env local; NÃO commite secrets)
# =============================================================================

# --- PostgreSQL (Railway plugin injeta DATABASE_URL automaticamente) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
POSTGRES_USER=csleague
POSTGRES_PASSWORD=change-me
POSTGRES_DB=csleague

# --- Redis (Railway plugin injeta REDIS_URL automaticamente) ---
REDIS_URL=redis://HOST:6379

# --- API ---
PORT=3000
JWT_SECRET=change-me-use-long-random-string
CORS_ORIGIN=https://seu-app.up.railway.app

# Armazenamento persistente (monte o mesmo volume na API e no Worker)
DEMO_STORAGE_PATH=/data/demos
TEAM_LOGO_STORAGE_PATH=/data/team-logos

# Opcional: força servir o frontend buildado (detectado automaticamente se /public existir)
# SERVE_FRONTEND=true
