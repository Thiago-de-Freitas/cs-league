# cs-league-worker — variáveis do Worker (Root Directory = Worker)
# Importar: railway variable import --file railway.env --service cs-league-worker --yes
#
# BACKEND_INTERNAL_URL: use o NOME EXATO do serviço da API no dashboard Railway (ex.: cs-league-back).
# NÃO use o nome do projeto (cs-league). A porta vem de ${{cs-league-back.PORT}} — se ficar vazia, a URL fica http://...:: e falha.
# Alternativa manual: http://cs-league-back.railway.internal:8080 (confira PORT nos logs do cs-league-back)

DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}
DEMO_STORAGE_PATH=/data/demos
BACKEND_INTERNAL_URL=http://${{cs-league-back.RAILWAY_PRIVATE_DOMAIN}}:${{cs-league-back.PORT}}
INTERNAL_SERVICE_KEY=${{shared.INTERNAL_SERVICE_KEY}}
