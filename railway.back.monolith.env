# cs-league-api — Opção A (um serviço só: API + front no mesmo domínio)
# Importar: railway variable import --file railway.back.monolith.env --service cs-league-api --yes

NODE_ENV=production
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}
JWT_SECRET=${{shared.JWT_SECRET}}
JWT_EXPIRES_IN=2d
CORS_ORIGIN=https://${{RAILWAY_PUBLIC_DOMAIN}}
DEMO_STORAGE_PATH=/data/demos
TEAM_LOGO_STORAGE_PATH=/data/team-logos
USER_AVATAR_STORAGE_PATH=/data/user-avatars
