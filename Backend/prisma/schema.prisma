generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TeamMemberRole {
  CAPTAIN
  MEMBER
}

enum PlayerPosition {
  AWP
  RIFLER
  ENTRY
  LURKER
  IGL
  SUPPORT
  FLEX
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum LeagueStatus {
  UPCOMING
  ONGOING
  COMPLETED
  ARCHIVED
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LeagueFormat {
  SINGLE_ELIMINATION
  GROUP_STAGE
  ONE_VS_ONE
}

enum SeriesFormat {
  BO1
  BO3
}

enum SeriesVetoStatus {
  BAN_PHASE
  PICK_PHASE
  MAPS_ASSIGNED
  COMPLETED
}

enum GameSide {
  CT
  T
}

enum MapVetoStatus {
  BAN_PHASE
  MAP_DECIDED
  SIDE_PHASE
  COMPLETED
}

enum HighlightType {
  MULTI_KILL
  ACE
  CLUTCH
  OPENING_KILL
}

enum HighlightClipRenderStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  UNAVAILABLE
}

enum MatchPhase {
  GROUP
  PLAYOFF
}

enum DemoStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AuditActorType {
  USER
  SYSTEM
  WORKER
  ANONYMOUS
}

enum PickupBalanceMode {
  RATING
  ADR
  HS_PERCENT
  POSITION_MIX
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  steamId      String?
  avatarUrl    String?
  position     PlayerPosition?
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  bannedUntil  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedTeams   Team[]       @relation("TeamOwner")
  memberships  TeamMember[]
  invites      TeamInvite[] @relation("InvitedUser")
  ownedLeagues League[]     @relation("LeagueOwner")
  demos        Demo[]
  auditEvents  AuditEvent[] @relation("AuditActor")
  leaguePlayerEntries LeaguePlayerEntry[]
}

model Team {
  id        String   @id @default(cuid())
  name      String
  tag       String
  logoUrl   String?
  ownerId   String
  leagueId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner       User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  league      League?      @relation("EphemeralTeams", fields: [leagueId], references: [id], onDelete: Cascade)
  members     TeamMember[]
  invites     TeamInvite[]
  leagueTeams LeagueTeam[]
  leaguePlayerEntries LeaguePlayerEntry[]
  matchesAsTeam1 Match[]   @relation("MatchTeam1")
  matchesAsTeam2 Match[]   @relation("MatchTeam2")
  matchesWon     Match[]   @relation("MatchWinner")

  @@index([leagueId])
}

model TeamMember {
  id         String          @id @default(cuid())
  teamId     String
  userId     String
  role       TeamMemberRole  @default(MEMBER)
  memberTag  String?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamInvite {
  id            String       @id @default(cuid())
  teamId        String
  invitedUserId String
  status        InviteStatus @default(PENDING)
  createdAt     DateTime     @default(now())

  team        Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedUser User @relation("InvitedUser", fields: [invitedUserId], references: [id], onDelete: Cascade)

  @@unique([teamId, invitedUserId])
}

model League {
  id                String       @id @default(cuid())
  name              String
  description       String       @default("")
  status            LeagueStatus @default(UPCOMING)
  format            LeagueFormat @default(SINGLE_ELIMINATION)
  maxTeams          Int?
  bracketSize       Int?
  groupCount        Int          @default(2)
  advancePerGroup   Int          @default(2)
  homeAndAway       Boolean      @default(false)
  matchesPerMatchDay Int         @default(0)
  registrationOpen  Boolean      @default(false)
  ownerId           String
  startDate         DateTime?
  endDate           DateTime?
  defaultMatchDays  Json?
  defaultMatchTime  String       @default("20:00")
  scheduleTimezone  String       @default("America/Sao_Paulo")
  mapPool           Json?
  mapVetoEnabled    Boolean      @default(true)
  seriesFormat      SeriesFormat @default(BO1)
  pickupTeamCount      Int?
  pickupPlayersPerTeam Int          @default(5)
  pickupBalanceMode    PickupBalanceMode   @default(RATING)
  pickupBalanceModes   PickupBalanceMode[] @default([RATING])
  pickupBalancedAt     DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  owner           User                 @relation("LeagueOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  teams           LeagueTeam[]
  groups          LeagueGroup[]
  matches         Match[]
  scheduleWeeks   LeagueScheduleWeek[]
  matchSeries     MatchSeries[]
  playerEntries   LeaguePlayerEntry[]
  ephemeralTeams  Team[]               @relation("EphemeralTeams")
}

model LeaguePlayerEntry {
  id        String   @id @default(cuid())
  leagueId  String
  userId    String
  teamId    String?
  createdAt DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team?  @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([leagueId, userId])
  @@index([leagueId])
  @@index([teamId])
}

model LeagueScheduleWeek {
  id         String   @id @default(cuid())
  leagueId   String
  weekStart  DateTime
  daysOfWeek Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, weekStart])
  @@index([leagueId])
}

model LeagueGroup {
  id       String @id @default(cuid())
  leagueId String
  name     String
  order    Int    @default(0)

  league  League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  teams   LeagueTeam[]
  matches Match[]

  @@unique([leagueId, name])
  @@index([leagueId])
}

model LeagueTeam {
  id       String @id @default(cuid())
  leagueId String
  teamId   String
  groupId  String?
  wins       Int    @default(0)
  losses     Int    @default(0)
  draws      Int    @default(0)
  points     Int    @default(0)
  roundsWon  Int    @default(0)
  roundsLost Int    @default(0)
  seed       Int?

  league League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team   Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  group  LeagueGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([leagueId, teamId])
}

model Match {
  id              String      @id @default(cuid())
  leagueId        String
  team1Id         String
  team2Id         String
  winnerId        String?
  status          MatchStatus @default(SCHEDULED)
  phase           MatchPhase  @default(PLAYOFF)
  groupId         String?
  groupRound      Int?
  round           Int         @default(1)
  bracketPosition Int?
  map             String?
  team1Rounds     Int?
  team2Rounds     Int?
  team1StartingSide GameSide?
  team2StartingSide GameSide?
  seriesId          String?
  seriesGameNumber  Int?
  scheduledAt     DateTime?
  playedAt        DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  league  League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  group   LeagueGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  team1   Team         @relation("MatchTeam1", fields: [team1Id], references: [id])
  team2   Team         @relation("MatchTeam2", fields: [team2Id], references: [id])
  winner  Team?        @relation("MatchWinner", fields: [winnerId], references: [id])
  demos   Demo[]
  mapVeto   MatchMapVeto?
  lineup    MatchLineup[]
  images    MatchImage[]
  highlights MatchHighlight[]
  series   MatchSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@index([leagueId])
  @@index([seriesId])
  @@index([groupId])
  @@index([leagueId, phase])
}

model Demo {
  id           String     @id @default(cuid())
  matchId      String?
  uploadedById String
  filePath     String?
  fileName     String?
  status       DemoStatus @default(PENDING)
  isPersonal   Boolean    @default(false)
  isManual     Boolean    @default(false)
  errorMessage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  match      Match?            @relation(fields: [matchId], references: [id], onDelete: SetNull)
  uploadedBy User              @relation(fields: [uploadedById], references: [id])
  stats      MatchPlayerStat[]
  highlights DemoHighlight[]

  @@index([matchId])
  @@index([uploadedById, isPersonal])
  @@index([status, isPersonal])
}

model MatchPlayerStat {
  id         String  @id @default(cuid())
  demoId     String
  teamId     String?
  steamId    String?
  playerName String
  kills      Int     @default(0)
  deaths     Int     @default(0)
  assists    Int     @default(0)
  damage     Int     @default(0)
  adr        Float   @default(0)
  hsPercent  Float   @default(0)
  kast       Float   @default(0)

  demo Demo @relation(fields: [demoId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id            String         @id @default(cuid())
  occurredAt    DateTime       @default(now())
  actorType     AuditActorType
  actorUserId   String?
  actorLabel    String?
  action        String
  entityType    String
  entityId      String?
  parentType    String?
  parentId      String?
  requestMethod String?
  requestPath   String?
  ipAddress     String?
  userAgent     String?
  correlationId String?
  before        Json?
  after         Json?
  metadata      Json?
  success       Boolean        @default(true)
  errorCode     String?

  actorUser User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([occurredAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([parentType, parentId])
  @@index([actorUserId])
  @@index([action])
}

model MatchSeries {
  id                String           @id @default(cuid())
  leagueId          String
  team1Id           String
  team2Id           String
  format            SeriesFormat     @default(BO1)
  team1MapWins      Int              @default(0)
  team2MapWins      Int              @default(0)
  winnerId          String?
  status            MatchStatus      @default(SCHEDULED)
  mapPool           Json
  bannedMaps        Json             @default("[]")
  pickedMaps        Json             @default("[]")
  firstActionTeamId String
  vetoTurnTeamId    String?
  vetoStatus        SeriesVetoStatus @default(BAN_PHASE)
  activeGameNumber  Int              @default(1)
  autoResolved      Boolean          @default(false)
  vetoReopenedByAdmin Boolean        @default(false)
  lastActionAt      DateTime         @default(now())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  league  League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  matches Match[]

  @@index([leagueId])
}

model MatchMapVeto {
  id             String        @id @default(cuid())
  matchId        String        @unique
  mapPool        Json
  bannedMaps     Json          @default("[]")
  firstBanTeamId String
  vetoTurnTeamId String?
  sidePickTeamId String?
  status         MapVetoStatus @default(BAN_PHASE)
  autoResolved   Boolean       @default(false)
  vetoReopenedByAdmin Boolean  @default(false)
  lastActionAt   DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model MatchLineup {
  id      String @id @default(cuid())
  matchId String
  teamId  String
  userId  String

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, teamId])
  @@index([matchId])
}

model MatchImage {
  id           String   @id @default(cuid())
  matchId      String
  imageUrl     String
  caption      String?
  uploadedById String
  createdAt    DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
}

model MatchHighlight {
  id          String        @id @default(cuid())
  matchId     String
  demoId      String?
  round       Int
  tick        Int?
  steamId     String?
  playerName  String
  type        HighlightType
  description String
  score                 Float                     @default(0)
  clipStartTick         Int?
  clipEndTick           Int?
  clipRenderStatus      HighlightClipRenderStatus @default(PENDING)
  clipVideoPath         String?
  clipRenderError       String?
  metadata              Json?
  createdAt             DateTime                  @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
}

model DemoHighlight {
  id          String        @id @default(cuid())
  demoId      String
  round       Int
  tick        Int?
  steamId     String?
  playerName  String
  type        HighlightType
  description String
  score                 Float                     @default(0)
  clipStartTick         Int?
  clipEndTick           Int?
  clipRenderStatus      HighlightClipRenderStatus @default(PENDING)
  clipVideoPath         String?
  clipRenderError       String?
  metadata              Json?
  createdAt             DateTime                  @default(now())

  demo Demo @relation(fields: [demoId], references: [id], onDelete: Cascade)

  @@index([demoId])
}
