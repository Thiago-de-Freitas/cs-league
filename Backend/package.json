{
  "name": "cs-league-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "version:generate": "node scripts/generate-version.mjs",
    "prebuild": "npm run version:generate",
    "build": "tsc",
    "predev": "npm run version:generate",
    "prestart": "npm run build",
    "pretest": "npm run version:generate",
    "start": "node dist/index.js",
    "start:prod": "prisma migrate deploy && node dist/index.js",
    "postinstall": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "demos:clean": "tsx scripts/clean-demos.ts",
    "test": "tsx --test src/**/*.test.ts",
    "worker:dev": "powershell -ExecutionPolicy Bypass -File ../Worker/run-dev.ps1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
